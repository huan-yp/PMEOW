{
  "name": "server-monitor",
  "private": true,
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "server/*"
  ],
  "description": "PMEOW - GPU cluster monitoring and scheduling platform for labs",
  "scripts": {
    "build:web": "node ./scripts/workspace-task.mjs build:web",
    "run:web": "node ./scripts/run-web-server.mjs",
    "dev:web": "node ./scripts/workspace-task.mjs dev:web",
    "dev:mobile": "node ./scripts/workspace-task.mjs dev:mobile",
    "run:mobile:android": "node ./scripts/workspace-task.mjs run:mobile:android",
    "build:mobile:apk": "node ./scripts/workspace-task.mjs build:mobile:apk",
    "check:web": "node ./scripts/workspace-task.mjs check:web",
    "check:mobile": "node ./scripts/workspace-task.mjs check:mobile"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
